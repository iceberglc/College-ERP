# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── Django core ──────────────────────────────────────────────────────────────
# Required in production. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Set to True for local development only. Defaults to False (production-safe).
DJANGO_DEBUG=True

# Comma-separated hostnames. Required when DJANGO_DEBUG=False.
# Example: DJANGO_ALLOWED_HOSTS=app.iceberglc.com
DJANGO_ALLOWED_HOSTS=app.iceberglc.com

# ── Uploads / media storage (IMPORTANT — protects uploads from deploys) ─────
# User uploads (profile pictures, chat attachments, story images, result
# files) must NOT live inside the repo clone, or a re-clone / git clean /
# platform redeploy will delete them. Pick ONE of these options:
#
# Option A — VPS: store uploads in a directory outside the repo.
#   deploy/setup.sh creates /home/iceberg/media and sets this automatically;
#   nginx serves it at /media/.
#DJANGO_MEDIA_ROOT=/home/iceberg/media
#
# Option B — DigitalOcean Spaces (S3-compatible object storage).
#   Required on App Platform / any host with an ephemeral filesystem.
#   When set, uploads bypass local disk entirely and survive every deploy.
#SPACES_KEY=
#SPACES_SECRET=
#SPACES_BUCKET=iceberg-media
#SPACES_REGION=fra1
#
# If neither is configured in production, `manage.py check --deploy`
# raises warning main_app.W001.

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (local dev).
# For Digital Ocean managed PostgreSQL, paste the connection string from the
# database console, e.g.:
#   DATABASE_URL=postgresql://user:pass@host:25060/db?sslmode=require
DATABASE_URL=

# ── Test / seed accounts (DEBUG only) ────────────────────────────────────────
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=admin123

# ── Recovery admin ────────────────────────────────────────────────────────────
RECOVERY_ADMIN_ENABLED=1
RECOVERY_ADMIN_EMAIL=iceberg.edu.center@gmail.com
RECOVERY_ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Leave blank in development — reset emails are saved to sent_emails/ instead.
# For Gmail: use an App Password (myaccount.google.com → Security → App passwords).
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── CORS (production) ────────────────────────────────────────────────────────
# Allow the public marketing/registration website to submit leads to this ERP.
CORS_ALLOWED_ORIGINS=https://iceberglc.com,https://www.iceberglc.com

# ── Public website registration forwarding ──────────────────────────────────
# Must match REGISTRATION_LEADS_API_TOKEN configured on the public website.
# The website should POST to either URL:
#   https://app.iceberglc.com/public/registration-leads/
#   https://app.iceberglc.com/public/registration-leads
# Send the token as one of:
#   Authorization: Bearer <token>
#   X-Registration-Token: <token>
#   X-API-Key: <token>
REGISTRATION_LEADS_API_TOKEN=change-me-to-a-shared-random-token

# ── Firebase Cloud Messaging ──────────────────────────────────────────────────
# Server-side: used by the notification-sender code path.
FCM_SERVER_KEY=

# Web/client-side: emitted into firebase-messaging-sw.js. Leave blank
# to disable FCM entirely (page renders a no-op service worker).
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ── CSRF / proxy origins ─────────────────────────────────────────────────────
# Optional comma-separated trusted origins for POSTs through proxies.
# Django 5 requires schemes, for example:
# CSRF_TRUSTED_ORIGINS=https://app.iceberglc.com,https://*.app.github.dev
CSRF_TRUSTED_ORIGINS=

# ── Optional Google reCAPTCHA ────────────────────────────────────────────────
# Leave CAPTCHA_ENABLED=False unless keys are configured for the exact hostname.
CAPTCHA_ENABLED=False
CAPTCHA_SITE_KEY=your-google-recaptcha-site-key
CAPTCHA_SECRET_KEY=your-google-recaptcha-secret-key
